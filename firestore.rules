rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) && 
             data.keys().size() == 3 &&
             data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['email']) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && existing().userId == request.auth.uid;
    }

    function isValidVaultEntry(data) {
      return data.keys().hasAll(['userId', 'name', 'type', 'encryptedData', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 &&
             data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.name is string && data.name.size() <= 256 &&
             data.type is string && data.type.size() <= 64 &&
             data.encryptedData is string && data.encryptedData.size() <= 100000 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /vault/{vaultId} {
      allow get: if isSignedIn() && isValidId(vaultId) && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(vaultId) && isValidVaultEntry(incoming()) && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(vaultId) && existing().userId == request.auth.uid && isValidVaultEntry(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'type', 'encryptedData', 'updatedAt']) && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt && incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isValidId(vaultId) && existing().userId == request.auth.uid;
    }
  }
}
